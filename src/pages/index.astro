---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import CTAButtons from '../components/CTAButtons.astro';
import { siteConfig, withBase } from '../config/site';

const heroStats = [
  { label: 'Location', value: 'Crawford, CO' },
  { label: 'Lead Time', value: siteConfig.leadTime },
  { label: 'Delivery', value: 'Available (details on request)' },
  { label: 'Custom Cuts', value: 'Up to 40ft beams' },
];

---
<BaseLayout title={siteConfig.companyName} description={siteConfig.description}>
  <Hero
    title={siteConfig.companyName}
    description="Locally owned and operated, Anchor Timber mills premium Aspen tongue-and-groove, blue stain pine, beams up to 40' in length, and other custom milled lumber and logs."
    stats={heroStats}
  />

  <Section
    eyebrow="Products"
    title="Milled for Your Build"
    subtitle="Check out the products page for more details and images of Anchor Timber products."
  >
    <div class="grid grid-3">
      <Card
        title="Aspen Tongue-and-Groove"
        text="Featured product with consistent profiles, smooth faces, and a kiln dried precise fit."
      />
      <Card
        title="Blue Stain Pine"
        text="Character-rich pine boards with natural blue stain for rustic interiors and accent work."
      />
      <Card title="Beams & Timbers" text="Up to 40ft lengths with multiple species available." />
      <Card title="Dimensional Lumber" text="Custom milled upon request and sometimes in stock." />
      <Card title="Ranch & Fencing" text="Material for posts, rails, planks, stays and more." />
      <Card title="Custom Orders" text="Special species, profiles, and requests. Call to get a quote on your material needs." />
    </div>
  </Section>

  <Section
    eyebrow="Services"
    title="Custom Milling Services"
    subtitle="Bring logs or a cut list and we will handle the milling, surfacing, and delivery."
  >
    <div class="grid grid-3">
      <Card title="Planing & Surfacing" text="Smooth, ready-to-install material with consistent thickness." />
      <Card title="Drying / Kiln Drying" text="Seasoning options available as needed (confirm availability)." />
      <Card title="Specialty Cuts" text="Custom dimensions, large beams, and unique profiles." />
      <Card title="Delivery" text="Schedule pickup or delivery across the Western Slope." />
    </div>
  </Section>

  <Section eyebrow="Gallery" title="Recent Work" subtitle="Placeholder previews for Blue Stain Pine, beams, and Aspen T&G.">
    <div class="gallery-grid">
      {Array.from({ length: 8 }).map(() => (
        <div class="gallery-item"></div>
      ))}
    </div>
  </Section>

</BaseLayout>
